# Copy to backend/.env and fill in values.
# The app loads RecipeAI/.env first, then backend/.env (backend wins for duplicate keys).

# Google AI Studio / Gemini (free tier) — required when video import uses AI (use_ai: true)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...

# Same as GEMINI_API_KEY if you prefer the name Google uses in some docs:
# GOOGLE_API_KEY=...

# Optional model id (default: gemini-2.0-flash-lite). See https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=gemini-2.0-flash-lite
# GEMINI_MODEL_FALLBACKS=gemini-2.0-flash-lite,gemini-1.5-flash,gemini-2.0-flash
# On 429 quota, fall back to heuristic parsing instead of failing (default: true)
# GEMINI_FALLBACK_ON_QUOTA=true

# YouTube often requires logged-in cookies for yt-dlp (fixes "Sign in to confirm you're not a bot").
# Option A: path to Netscape cookies.txt (relative paths are resolved from the backend/ folder)
# YTDLP_COOKIES_FILE=cookies/youtube.txt
#
# Option B: read cookies from a local browser profile (dev machines only; server needs a cookie file instead)
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_FROM_BROWSER=firefox:profile-name
#
# Optional: override YouTube player_client rotation (comma-separated). Use "off" to disable.
# YTDLP_YOUTUBE_PLAYER_CLIENTS=android,web,ios,mweb,tv_embedded
#
# See https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
