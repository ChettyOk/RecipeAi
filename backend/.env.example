# Copy to backend/.env and fill in values.
# The app loads the project root .env first, then backend/.env (backend wins for duplicate keys).

# ── Google AI Studio / Gemini (free tier) — recipe parsing + (optional) audio/vision ──
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...
# GOOGLE_API_KEY=...                 # accepted as an alias for GEMINI_API_KEY
# GEMINI_MODEL=gemini-2.0-flash-lite
# GEMINI_MODEL_FALLBACKS=gemini-2.0-flash-lite,gemini-1.5-flash,gemini-2.0-flash
# GEMINI_FALLBACK_ON_QUOTA=true       # on 429, fall back to heuristic parsing

# ── Media pipeline: download video + ffmpeg + Gemini transcription/frame OCR ──
# Requires system ffmpeg/ffprobe. Off by default (captions/description only when off).
# ENABLE_MEDIA_PIPELINE=false
# ENABLE_TRANSCRIPTION=true
# ENABLE_FRAME_VISION=true
# FRAME_INTERVAL_SEC=4
# MAX_FRAMES=8
# MAX_VIDEO_SECONDS=240
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe

# ── Nutrition: USDA FoodData Central (free) ──
# https://fdc.nal.usda.gov/api-key-signup.html
# Strongly recommended for accurate per-ingredient estimates (used per line, with local fallback).
# USDA_API_KEY=...
# ENABLE_NUTRITION=true
# ENABLE_GEMINI_NUTRITION=false   # off by default — Gemini nutrition is non-deterministic; caption parse is preferred

# ── yt-dlp cookies / YouTube hardening (see README "YouTube cookies") ──
# YTDLP_COOKIES_FILE=cookies/youtube.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_YOUTUBE_PLAYER_CLIENTS=android,web,ios,mweb,tv_embedded

# Extra browser origins allowed to call the API (comma-separated). Vite dev server is always allowed.
# EXTRA_CORS_ORIGINS=https://your-pwa.example

# ── Production (Docker / Render) ──
# DATA_DIR=/data              # SQLite + thumbnails (use a persistent volume)
# STATIC_DIR=/app/static      # Vite build copied here by Dockerfile
# PORT=8000                   # Set automatically on Render/Fly
